# AI Tutor Backend — Environment Variables

# Database (SQLite default, swap to PostgreSQL for production)
DATABASE_URL=sqlite:///./ai_tutor.db

# AI Provider — OpenCode Zen (DeepSeek V4 Flash Free, NO key needed)
AI_PROVIDER=opencode
AI_MODEL=deepseek-v4-flash-free
AI_BASE_URL=https://opencode.ai/zen/v1

# Spaced Repetition
REVIEW_INTERVAL_BASE_HOURS=24
MASTERY_INCREASE_ON_CORRECT=10.0
MASTERY_DECREASE_ON_WRONG=-15.0
